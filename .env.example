# Enphase Envoy S-Metered
ENVOY_HOST=192.168.1.x
ENVOY_USER=your@email.com
ENVOY_PASSWORD=your_password
# Set to true if an Enphase battery (IQ Battery) is installed
# false → uses /ivp/meters/readings (activePower)
# true  → uses /ivp/livedata/status (agg_p_mw, includes storage)
BATTERY_INSTALLED=false

# MQTT broker
MQTT_HOST=192.168.1.y
MQTT_PORT=1883
MQTT_USER=
MQTT_PASSWORD=
# TLS: set MQTT_USE_TLS=true to enable SSL (typical port: 8883)
MQTT_USE_TLS=false
# Path to CA certificate file; leave empty to use the system CA
MQTT_CA_CERT=
# Set to true to skip certificate verification (self-signed brokers)
MQTT_INSECURE=false

# MQTT topics (must match the Trydan configuration)
TOPIC_SUN=trydan/trydan_v2c_sun_power
TOPIC_GRID=trydan/trydan_v2c_grid_power
TOPIC_BATTERY=trydan/trydan_v2c_battery_power

# Seconds between polling requests to the Envoy (only used when BATTERY_INSTALLED=false)
POLL_INTERVAL=0.6

# Seconds between reconnect attempts
RECONNECT_DELAY=5

# Debug mode (logs raw SSE lines, decoded JSON, auth and MQTT details)
DEBUG=false
